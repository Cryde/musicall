{% extends 'pdf/setlist/_base.html.twig' %}

{% block extra_styles %}
        {% set s = scale|default(1) %}
        .compact-header {
            margin-bottom: {{ (10 * s)|round(2) }}mm;
        }
        .compact-header .band {
            font-size: {{ (11 * s)|round(2) }}pt;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.5pt;
        }
        .compact-header .name {
            font-size: {{ (26 * s)|round(2) }}pt;
            font-weight: bold;
            margin-top: 1mm;
        }

        ol.stage-items {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        ol.stage-items li {
            padding: {{ (6 * s)|round(2) }}mm 0;
            border-bottom: 1px solid #eee;
            page-break-inside: avoid;
        }
        .stage-row {
            display: table;
            width: 100%;
        }
        .stage-num, .stage-title {
            display: table-cell;
            vertical-align: middle;
        }
        .stage-num {
            width: {{ (22 * s)|round(2) }}mm;
            font-size: {{ (32 * s)|round(2) }}pt;
            font-weight: bold;
            color: #f5b400;
            font-variant-numeric: tabular-nums;
        }
        .stage-title {
            font-size: {{ (38 * s)|round(2) }}pt;
            font-weight: bold;
            line-height: 1.1;
        }
        li.non-song .stage-num {
            color: #bbb;
            font-size: {{ (22 * s)|round(2) }}pt;
            font-weight: normal;
        }
        li.non-song .stage-title {
            font-size: {{ (22 * s)|round(2) }}pt;
            font-style: italic;
            color: #777;
            font-weight: normal;
        }
{% endblock %}

{% block header %}
    <div class="pdf-header compact-header">
        <div class="band">{{ setlist.bandSpace.name }}</div>
        <div class="name">{{ setlist.name }}</div>
        <hr class="pdf-header-rule">
    </div>
{% endblock %}

{% block body %}
    <ol class="stage-items">
        {% for item in setlist.items %}
            <li class="{{ item.type.value != 'song' ? 'non-song' : '' }}">
                <div class="stage-row">
                    <div class="stage-num">{{ loop.index }}</div>
                    <div class="stage-title">
                        {% if item.type.value == 'song' and item.song %}
                            {{ item.song.title }}
                        {% else %}
                            {{ item.label ?: '—' }}
                        {% endif %}
                    </div>
                </div>
            </li>
        {% endfor %}
    </ol>
{% endblock %}
