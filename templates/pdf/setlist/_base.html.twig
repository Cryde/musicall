<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{{ setlist.name }}</title>
    <style>
        @page { margin: 18mm 14mm 22mm 14mm; }
        body { font-family: '{{ font_family|default('Inter') }}', sans-serif; color: #1a1a1a; }

        .pdf-header { margin-bottom: 8mm; }
        .pdf-header-rule {
            height: 0;
            border: 0;
            border-top: 2px solid #f5b400;
            margin: 0 0 6mm 0;
        }

        {% block extra_styles %}{% endblock %}
    </style>
</head>
<body>
    {% block header %}{% endblock %}
    {% block body %}{% endblock %}
</body>
</html>
